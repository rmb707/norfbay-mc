# Copy this file to ".env" and fill in values. NEVER commit .env (it's git-ignored).

# ---- Minecraft servers (Phase 1) ----------------------------------------------
# RCON password shared by the servers + web app + backups. Use a long random string.
RCON_PASSWORD=change-me-to-a-long-random-string

# Your Minecraft (Java) username, made server op + whitelisted at first boot.
# Leave blank and add yourself later with:  docker compose exec cobblemon rcon-cli whitelist add <name>
MC_OWNER=
# Comma-separated usernames to seed on the whitelist (optional).
MC_WHITELIST=

# ---- Public game access via playit.gg (profile: public) -----------------------
# Create a free account at https://playit.gg, run the agent once to claim it,
# then paste the agent secret here. Point minecraft.norfbay.com (CNAME) at the tunnel.
PLAYIT_SECRET=

# ---- Website + auth (profile: web) --------------------------------------------
# Auth.js session secret:  openssl rand -base64 32
AUTH_SECRET=
# Google OAuth client (Google Cloud Console -> Credentials -> OAuth client, Web).
# Authorized redirect URI: https://play.norfbay.com/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Comma-separated friend emails allowed to sign in.
ALLOWED_EMAILS=robseris@gmail.com

# Cloudflare Tunnel token (Zero Trust -> Networks -> Tunnels -> create -> token).
# Route play.norfbay.com -> http://web:3000 inside the tunnel config.
CF_TUNNEL_TOKEN=
